<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Resume - <%= name %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Lora', 'Georgia', serif; font-size: 11px; color: #333; line-height: 1.5; padding: 36px 44px; max-width: 210mm; }
    .resume { display: flex; gap: 28px; }
    .sidebar { width: 34%; background: <%= typeof themeColorLight !== 'undefined' ? themeColorLight : '#f5f5f5' %>; padding: 24px 20px; border-radius: 4px; }
    .main { flex: 1; }
    .header { text-align: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #e0e0e0; }
    .photo { width: 100px; height: 100px; border-radius: 50%; object-fit: cover; margin: 0 auto 12px; display: block; border: 3px solid <%= typeof themeColor !== 'undefined' ? themeColor : '#8b7355' %>; }
    .name { font-size: 24px; font-weight: 600; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#5c4a3a' %>; margin-bottom: 4px; }
    .job-title { font-size: 12px; color: #777; }
    .sidebar h2 { font-size: 11px; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#8b7355' %>; text-transform: uppercase; letter-spacing: 1.2px; margin: 20px 0 10px; padding-bottom: 6px; border-bottom: 1px solid <%= typeof themeColor !== 'undefined' ? themeColor : '#c4b59a' %>; }
    .sidebar h2:first-of-type { margin-top: 0; }
    .sidebar p, .sidebar .item { margin-bottom: 6px; color: #555; font-size: 10px; }
    .skill { display: inline-block; background: <%= typeof themeColor !== 'undefined' ? themeColor : '#8b7355' %>; color: #fff; padding: 3px 8px; border-radius: 3px; font-size: 9px; margin: 2px 4px 2px 0; }
    .edu-item { margin-bottom: 12px; }
    .edu-degree { font-weight: 600; color: #333; font-size: 10px; }
    .edu-years { font-size: 9px; color: #777; }
    .main h2 { font-size: 12px; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#5c4a3a' %>; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; padding-bottom: 6px; border-bottom: 2px solid <%= typeof themeColor !== 'undefined' ? themeColor : '#8b7355' %>; }
    .profile { margin-bottom: 22px; text-align: justify; color: #444; }
    .job { margin-bottom: 20px; }
    .job-dates { font-size: 10px; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#8b7355' %>; margin-bottom: 2px; }
    .job-company { font-weight: 600; color: #333; margin-bottom: 2px; }
    .job-position { font-style: italic; margin-bottom: 6px; color: #555; }
    .job-desc ul { margin-left: 18px; margin-top: 4px; }
    .job-desc li { margin-bottom: 2px; color: #444; }
  </style>
</head>
<body>
  <div class="resume">
    <div class="sidebar">
      <div class="header">
        <% if (typeof photoDataUrl !== 'undefined' && photoDataUrl) { %>
        <img src="<%= photoDataUrl %>" alt="Photo" class="photo" />
        <% } %>
        <h1 class="name"><%= name %></h1>
        <p class="job-title"><%= jobTitle %></p>
      </div>
      <h2>Contact</h2>
      <p><%= phone %></p>
      <p><%= email %></p>
      <p><%= location %></p>
      <h2>Skills</h2>
      <div>
        <% (skills || []).filter(Boolean).forEach(function(skill) { %>
        <span class="skill"><%= skill %></span>
        <% }); %>
      </div>
      <h2>Education</h2>
      <% (education || []).forEach(function(edu) { %>
      <div class="edu-item">
        <div class="edu-degree"><%= edu.degree %></div>
        <div class="edu-years"><%= edu.startYear %> - <%= edu.endYear %></div>
      </div>
      <% }); %>
      <h2>Languages</h2>
      <% (languages || []).forEach(function(lang) { %>
      <p><%= lang.language %> — <%= lang.proficiency %></p>
      <% }); %>
    </div>
    <div class="main">
      <h2>Profile</h2>
      <div class="profile"><%= profile || '' %></div>
      <h2>Work Experience</h2>
      <% (workExperience || []).forEach(function(job) { %>
      <div class="job">
        <div class="job-dates"><%= job.startDate %> - <%= job.endDate %></div>
        <div class="job-company"><%= job.company %>, <%= job.jobLocation %></div>
        <div class="job-position"><%= job.position %></div>
        <% if (job.description && job.description.length) { %>
        <div class="job-desc">
          <ul>
            <% job.description.filter(Boolean).forEach(function(desc) { %>
            <li><%= desc %></li>
            <% }); %>
          </ul>
        </div>
        <% } %>
      </div>
      <% }); %>
    </div>
  </div>
</body>
</html>
