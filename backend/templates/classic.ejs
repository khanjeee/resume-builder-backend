<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Resume - <%= name %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Georgia', serif; font-size: 11px; color: #1a1a1a; line-height: 1.4; padding: 40px 50px; max-width: 210mm; }
    .resume { display: flex; gap: 30px; }
    .left { width: 38%; }
    .right { flex: 1; }
    .header { margin-bottom: 24px; display: flex; align-items: flex-start; gap: 24px; }
    .photo { width: 90px; height: 90px; border-radius: 6px; object-fit: cover; border: 2px solid <%= typeof themeColor !== 'undefined' ? themeColor : '#2d3748' %>; flex-shrink: 0; }
    .name { font-size: 22px; font-weight: bold; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#2d3748' %>; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .job-title { font-size: 13px; color: #718096; margin-bottom: 20px; }
    h2 { font-size: 12px; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#2d3748' %>; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; padding-bottom: 4px; border-bottom: 2px solid <%= typeof themeColor !== 'undefined' ? themeColor : '#2d3748' %>; }
    .contact p { margin-bottom: 6px; }
    .section { margin-bottom: 20px; }
    .skills-list { display: flex; flex-wrap: wrap; gap: 6px 12px; }
    .skill { background: <%= typeof themeColorLight !== 'undefined' ? themeColorLight : '#e2e8f0' %>; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#2d3748' %>; padding: 4px 10px; border-radius: 4px; font-size: 10px; }
    .profile { text-align: justify; margin-bottom: 20px; }
    .job { margin-bottom: 18px; }
    .job-dates { font-size: 10px; color: #718096; margin-bottom: 2px; }
    .job-company { font-weight: bold; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#1a1a1a' %>; margin-bottom: 2px; }
    .job-position { font-style: italic; margin-bottom: 6px; }
    .job-desc ul { margin-left: 18px; margin-top: 4px; }
    .job-desc li { margin-bottom: 2px; }
    .edu-item { margin-bottom: 12px; }
    .edu-degree { font-weight: bold; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#1a1a1a' %>; }
    .edu-years { font-size: 10px; color: #718096; }
    .lang-item { margin-bottom: 4px; }
  </style>
</head>
<body>
  <div class="resume">
    <div class="left">
      <div class="header">
        <% if (typeof photoDataUrl !== 'undefined' && photoDataUrl) { %>
        <img src="<%= photoDataUrl %>" alt="Photo" class="photo" />
        <% } %>
        <div>
          <h1 class="name"><%= name %></h1>
          <p class="job-title"><%= jobTitle %></p>
        </div>
      </div>
      <div class="section">
        <h2>Contact</h2>
        <div class="contact">
          <p><%= phone %></p>
          <p><%= email %></p>
          <p><%= location %></p>
        </div>
      </div>
      <div class="section">
        <h2>Skills</h2>
        <div class="skills-list">
          <% (skills || []).filter(Boolean).forEach(function(skill) { %>
          <span class="skill"><%= skill %></span>
          <% }); %>
        </div>
      </div>
      <div class="section">
        <h2>Education</h2>
        <% (education || []).forEach(function(edu) { %>
        <div class="edu-item">
          <div class="edu-degree"><%= edu.degree %></div>
          <div class="edu-years"><%= edu.startYear %> - <%= edu.endYear %></div>
        </div>
        <% }); %>
      </div>
      <div class="section">
        <h2>Languages</h2>
        <% (languages || []).forEach(function(lang) { %>
        <div class="lang-item"><%= lang.language %> (<%= lang.proficiency %>)</div>
        <% }); %>
      </div>
    </div>
    <div class="right">
      <div class="section">
        <h2>Profile</h2>
        <div class="profile"><%= profile || '' %></div>
      </div>
      <div class="section">
        <h2>Work Experience</h2>
        <% (workExperience || []).forEach(function(job) { %>
        <div class="job">
          <div class="job-dates"><%= job.startDate %> - <%= job.endDate %></div>
          <div class="job-company"><%= job.company %> — <%= job.jobLocation %></div>
          <div class="job-position"><%= job.position %></div>
          <% if (job.description && job.description.length) { %>
          <div class="job-desc">
            <ul>
              <% job.description.filter(Boolean).forEach(function(desc) { %>
              <li><%= desc %></li>
            <% }); %>
          </ul>
        </div>
        <% } %>
      </div>
      <% }); %>
    </div>
  </div>
</body>
</html>
