<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Resume - <%= name %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Open Sans', 'Helvetica Neue', Arial, sans-serif; font-size: 11px; color: #444; line-height: 1.5; padding: 40px 48px; max-width: 210mm; }
    .resume { display: flex; gap: 32px; }
    .sidebar { width: 36%; }
    .header { margin-bottom: 20px; }
    .photo { width: 96px; height: 96px; border-radius: 8px; object-fit: cover; border: 2px solid <%= typeof themeColor !== 'undefined' ? themeColor : '#2c3e50' %>; margin-bottom: 12px; display: block; }
    .name { font-size: 22px; font-weight: 700; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#2c3e50' %>; margin-bottom: 4px; }
    .job-title { font-size: 12px; color: #7f8c8d; margin-bottom: 20px; }
    .sidebar h2 { font-size: 11px; color: #fff; background: <%= typeof themeColor !== 'undefined' ? themeColor : '#2c3e50' %>; padding: 8px 12px; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
    .sidebar .contact p { margin-bottom: 6px; color: #555; font-size: 10px; }
    .sidebar .skill { display: block; margin-bottom: 4px; padding-left: 8px; border-left: 3px solid <%= typeof themeColor !== 'undefined' ? themeColor : '#3498db' %>; font-size: 10px; }
    .edu-item { margin-bottom: 14px; }
    .edu-degree { font-weight: 600; color: #2c3e50; font-size: 10px; }
    .edu-years { font-size: 9px; color: #7f8c8d; }
    .lang-item { margin-bottom: 4px; font-size: 10px; color: #555; }
    .main h2 { font-size: 11px; color: #fff; background: <%= typeof themeColor !== 'undefined' ? themeColor : '#2c3e50' %>; padding: 8px 12px; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
    .profile { margin-bottom: 22px; color: #555; text-align: justify; }
    .job { margin-bottom: 22px; }
    .job-dates { font-size: 10px; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#3498db' %>; margin-bottom: 2px; font-weight: 600; }
    .job-company { font-weight: 700; color: #2c3e50; margin-bottom: 2px; }
    .job-position { margin-bottom: 6px; color: #555; }
    .job-desc ul { margin-left: 18px; margin-top: 4px; }
    .job-desc li { margin-bottom: 2px; color: #555; }
  </style>
</head>
<body>
  <div class="resume">
    <div class="sidebar">
      <div class="header">
        <% if (typeof photoDataUrl !== 'undefined' && photoDataUrl) { %>
        <img src="<%= photoDataUrl %>" alt="Photo" class="photo" />
        <% } %>
        <h1 class="name"><%= name %></h1>
        <p class="job-title"><%= jobTitle %></p>
      </div>
      <h2>Contact</h2>
      <div class="contact">
        <p><%= phone %></p>
        <p><%= email %></p>
        <p><%= location %></p>
      </div>
      <h2>Skills</h2>
      <% (skills || []).filter(Boolean).forEach(function(skill) { %>
      <span class="skill"><%= skill %></span>
      <% }); %>
      <h2>Education</h2>
      <% (education || []).forEach(function(edu) { %>
      <div class="edu-item">
        <div class="edu-degree"><%= edu.degree %></div>
        <div class="edu-years"><%= edu.startYear %> - <%= edu.endYear %></div>
      </div>
      <% }); %>
      <h2>Languages</h2>
      <% (languages || []).forEach(function(lang) { %>
      <div class="lang-item"><%= lang.language %> — <%= lang.proficiency %></div>
      <% }); %>
    </div>
    <div class="main">
      <h2>Profile</h2>
      <div class="profile"><%= profile || '' %></div>
      <h2>Work Experience</h2>
      <% (workExperience || []).forEach(function(job) { %>
      <div class="job">
        <div class="job-dates"><%= job.startDate %> - <%= job.endDate %></div>
        <div class="job-company"><%= job.company %>, <%= job.jobLocation %></div>
        <div class="job-position"><%= job.position %></div>
        <% if (job.description && job.description.length) { %>
        <div class="job-desc">
          <ul>
            <% job.description.filter(Boolean).forEach(function(desc) { %>
            <li><%= desc %></li>
            <% }); %>
          </ul>
        </div>
        <% } %>
      </div>
      <% }); %>
    </div>
  </div>
</body>
</html>
