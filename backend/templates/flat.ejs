<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Resume - <%= name %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.5; padding: 32px 40px; max-width: 210mm; }
    .resume { display: flex; gap: 0; }
    .sidebar { width: 32%; background: <%= typeof themeColor !== 'undefined' ? themeColor : '#3498db' %>; color: #fff; padding: 28px 20px; }
    .sidebar .name { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
    .sidebar .job-title { font-size: 11px; opacity: 0.9; margin-bottom: 24px; }
    .photo { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid rgba(255,255,255,0.5); margin-bottom: 20px; display: block; }
    .sidebar h2 { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; margin: 22px 0 10px; padding-bottom: 6px; border-bottom: 2px solid rgba(255,255,255,0.4); }
    .sidebar h2:first-of-type { margin-top: 0; }
    .sidebar p, .sidebar .lang-item { margin-bottom: 6px; font-size: 10px; opacity: 0.95; }
    .sidebar .skill { display: block; margin-bottom: 4px; font-size: 10px; }
    .edu-item { margin-bottom: 10px; }
    .edu-degree { font-weight: 600; font-size: 10px; }
    .edu-years { font-size: 9px; opacity: 0.9; }
    .main { flex: 1; padding: 0 28px; }
    .main h2 { font-size: 11px; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#3498db' %>; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 2px solid <%= typeof themeColor !== 'undefined' ? themeColor : '#3498db' %>; }
    .profile { margin-bottom: 22px; color: #444; text-align: justify; }
    .job { margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #eee; }
    .job:last-child { border-bottom: none; }
    .job-dates { font-size: 10px; color: <%= typeof themeColor !== 'undefined' ? themeColor : '#3498db' %>; margin-bottom: 2px; font-weight: 600; }
    .job-company { font-weight: 700; color: #222; margin-bottom: 2px; }
    .job-position { margin-bottom: 6px; color: #555; }
    .job-desc ul { margin-left: 18px; margin-top: 4px; }
    .job-desc li { margin-bottom: 2px; color: #444; }
  </style>
</head>
<body>
  <div class="resume">
    <div class="sidebar">
      <% if (typeof photoDataUrl !== 'undefined' && photoDataUrl) { %>
      <img src="<%= photoDataUrl %>" alt="Photo" class="photo" />
      <% } %>
      <h1 class="name"><%= name %></h1>
      <p class="job-title"><%= jobTitle %></p>
      <h2>Contact</h2>
      <p><%= phone %></p>
      <p><%= email %></p>
      <p><%= location %></p>
      <h2>Skills</h2>
      <% (skills || []).filter(Boolean).forEach(function(skill) { %>
      <span class="skill"><%= skill %></span>
      <% }); %>
      <h2>Education</h2>
      <% (education || []).forEach(function(edu) { %>
      <div class="edu-item">
        <div class="edu-degree"><%= edu.degree %></div>
        <div class="edu-years"><%= edu.startYear %> - <%= edu.endYear %></div>
      </div>
      <% }); %>
      <h2>Languages</h2>
      <% (languages || []).forEach(function(lang) { %>
      <p class="lang-item"><%= lang.language %> — <%= lang.proficiency %></p>
      <% }); %>
    </div>
    <div class="main">
      <h2>Profile</h2>
      <div class="profile"><%= profile || '' %></div>
      <h2>Work Experience</h2>
      <% (workExperience || []).forEach(function(job) { %>
      <div class="job">
        <div class="job-dates"><%= job.startDate %> - <%= job.endDate %></div>
        <div class="job-company"><%= job.company %>, <%= job.jobLocation %></div>
        <div class="job-position"><%= job.position %></div>
        <% if (job.description && job.description.length) { %>
        <div class="job-desc">
          <ul>
            <% job.description.filter(Boolean).forEach(function(desc) { %>
            <li><%= desc %></li>
            <% }); %>
          </ul>
        </div>
        <% } %>
      </div>
      <% }); %>
    </div>
  </div>
</body>
</html>
